# Anthropic API — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Session encryption — generate with: openssl rand -base64 32
SESSION_SECRET=

# Database — MySQL connection string
DATABASE_URL="mysql://user:password@hostname:3306/shared_leash"

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret — https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price ID — create a "Shared Leash Premium" product ($9.99/mo) in Stripe, copy the price ID
STRIPE_PREMIUM_PRICE_ID=price_...

# App URL — used for Stripe redirect URLs
APP_URL=http://localhost:3000

# Cron secret — protects the monthly chat reset endpoint, any random string
CRON_SECRET=

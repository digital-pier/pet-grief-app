# Anthropic API — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Session encryption — generate with: openssl rand -base64 32
SESSION_SECRET=

# Database — Supabase PostgreSQL connection string (use Transaction pooler, port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret — https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price ID — create a "Shared Leash Premium" product ($9.99/mo) in Stripe, copy the price ID
STRIPE_PREMIUM_PRICE_ID=price_...

# App URL — used for Stripe redirect URLs
APP_URL=http://localhost:3000

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...

# From email for transactional emails (must be verified in Resend)
FROM_EMAIL=noreply@sharedleash.com

# Cron secret — protects the monthly chat reset endpoint, any random string
CRON_SECRET=

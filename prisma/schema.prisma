generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int            @id @default(autoincrement())
  name               String
  email              String         @unique
  passwordHash       String         @map("password_hash")
  createdAt          DateTime       @default(now()) @map("created_at")

  // Stripe & subscription fields (kept for future use)
  stripeCustomerId   String?        @map("stripe_customer_id")
  subscriptionStatus String         @default("free") @map("subscription_status")
  planTier           String         @default("free") @map("plan_tier")
  currentPeriodStart DateTime?      @map("current_period_start")
  currentPeriodEnd   DateTime?      @map("current_period_end")
  cancelAtPeriodEnd  Boolean        @default(false) @map("cancel_at_period_end")
  monthlyChatsUsed   Int            @default(0) @map("monthly_chats_used")
  monthlyChatsResetAt DateTime?     @map("monthly_chats_reset_at")

  // Crisis signal tracking
  crisisSignal       Boolean        @default(false) @map("crisis_signal")
  crisisSignalAt     DateTime?      @map("crisis_signal_at")

  // Admin
  isAdmin            Boolean        @default(false) @map("is_admin")

  // Password reset
  passwordResetToken     String?    @unique @map("password_reset_token")
  passwordResetExpiry    DateTime?  @map("password_reset_expiry")

  // Email verification
  emailVerified              DateTime?  @map("email_verified")
  emailVerificationToken     String?    @unique @map("email_verification_token")
  emailVerificationExpiry    DateTime?  @map("email_verification_expiry")

  conversation       Conversation?
  subscriptions      Subscription[]
  chatLogs           ChatLog[]

  @@map("users")
}

model Conversation {
  userId    Int      @id @map("user_id")
  messages  String   @default("[]")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("conversations")
}

model ChatLog {
  id                  Int      @id @default(autoincrement())
  requestId           String   @map("request_id")
  userId              Int      @map("user_id")
  model               String
  inputTokens         Int      @map("input_tokens")
  outputTokens        Int      @map("output_tokens")
  cacheCreationTokens Int      @default(0) @map("cache_creation_tokens")
  cacheReadTokens     Int      @default(0) @map("cache_read_tokens")
  serviceTier         String   @default("standard") @map("service_tier")
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("chat_logs")
}

model Subscription {
  id                   Int      @id @default(autoincrement())
  userId               Int      @map("user_id")
  stripeSubscriptionId String   @map("stripe_subscription_id")
  status               String
  planTier             String   @map("plan_tier")
  currentPeriodStart   DateTime @map("current_period_start")
  currentPeriodEnd     DateTime @map("current_period_end")
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}
